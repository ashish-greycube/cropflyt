 "doctype": "Print Format",
 "font_size": 14,
 "html": "{%- from \"templates/print_formats/standard_macros.html\" import add_header, render_field, print_value, fieldmeta, get_width, get_align_class with context -%}\n\n{% if print_settings.repeat_header_footer %}\n    <div id=\"header-html\">\n        {% if letter_head and not no_letterhead %}\n            <div class=\"letter-head\">{{ letter_head }}</div>\n        {% endif %}\n   </div>\n{% endif %}\n\n\n<table border=\"1\" style=\"width:100%; font-size:13px; margin-top:10px\">\n    <tr>\n        <td style=\"border-right:none;\"><b>Farmer Name :</b></td>\n        <td style=\"border-left:none;\">{{doc.farmer_name or \"\"}}</td>\n        <td style=\"border-right:none;\"><b>Mobile No :</b></td>\n        <td style=\"border-left:none;\">{{doc.mobile_number or \"\"}}</td>\n    </tr>\n    <tr>\n        <td style=\"border-right:none\"><b>Completion Date :</b></td>\n        <td style=\"border-left:none\">{{frappe.utils.format_date(doc.completion_date) or \"\"}}</td>\n        <td style=\"border-right:none\"><b>Village :</b></td>\n        <td style=\"border-left:none\">{{doc.village or \"\"}}</td>\n    </tr>\n    <tr>\n        <td style=\"border-right:none\"><b>Crop Type :</b></td>\n        <td style=\"border-left:none\">{{doc.crop_type or \"\"}}</td>\n        <td style=\"border-right:none\"><b>Area Sprayed Bigha :</b></td>\n        <td style=\"border-left:none\">{{doc.area_sprayed_bigha or \"\"}}</td>\n    </tr>\n    <tr>\n        <td style=\"border-right:none\"><b>Chemical :</b></td>\n        <td style=\"border-left:none\">{{doc.chemical or \"\"}}</td>\n        <td style=\"border-right:none\"><b>Dose Per Bigha :</b></td>\n        <td style=\"border-left:none\">{{doc.dose_per_bigha or \"\"}}</td>\n    </tr>\n    <tr>\n        <td style=\"border-right:none\"><b>Pilot Name :</b></td>\n        <td style=\"border-left:none\">{{doc.pilot_name or \"\"}}</td>\n        <td style=\"border-right:none\"><b>Drone Assigned :</b></td>\n        <td style=\"border-left:none\">{{doc.drone_assigned or \"\"}}</td>\n    </tr>\n</table>\n\n<div class=\"row section-break info-section\" style=\"margin-top:20px\">\n    <div class=\"col-xs-8 column-break\">\n        {% if doc.pre_spray_photo_reference%}\n        <p><b>Pre-Spray Photo</b></p>\n        <img style=\"height:200px; width:200px\" src=\"{{doc.pre_spray_photo_reference}}\" />\n        {% endif %}\n    </div>\n    <div class=\"col-xs-4 column-break\">\n        {% if doc.post_spray_photo_reference%}\n        <p><b>Post-Spray Photo</b></p>\n        <img style=\"height:200px; width:200px;\" src=\"{{doc.post_spray_photo_reference}}\" />\n        {% endif %}\n    </div>\n</div>\n\n<table style=\"width:100%; font-size:13px; margin-top:90px\">\n    <tr>\n        <td style=\"width:50%;\"><span style=\"border-top:1px solid black; padding-top:5px;\"><b>Farmer Signature</b></span></td>\n        <td style=\"width:50%; text-align:right\"><span style=\"border-top:1px solid black; padding-top:5px; \"><b>Cropflyt Representative Signature</b></span></td>\n    </tr>\n</table>\n\n{% if print_settings.repeat_header_footer %}\n<div id=\"footer-html\">\n    {% if footer %}\n    <div class=\"letter-head-footer\"> {{ footer }} </div>\n    {% endif %}\n    <p class=\"text-center small page-number visible-pdf\">\n        {{ _(\"Page {0} of {1}\").format('<span class=\"page\"></span>', '<span class=\"topage\"></span>') }} </p>\n</div>\n{% endif %}\n\n\n\n",
